generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


// ==========================================
// 4. USER & AUTHENTICATION
// ==========================================
model User {
  id           Int         @id @default(autoincrement())
  name         String
  username     String      @unique // Changed from email to username
  password     String      // Hashed password
  role         String      @default("TECHNICIAN")

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 1. MASTER DATA (For Dropdowns & Auto-fill)
// ==========================================
model TestProtocol {
  id                Int      @id @default(autoincrement())
  testName          String   @unique // e.g., TR, CR, CD, BD, "Temperature rise test: Wash"
  productType       String   @default("SATL") // [cite: dependent dropdown enhancement]
  testPurpose       String?  @db.Text 
  testMethod        String   @db.Text
  judgementCriteria String   @db.Text
  testDuration      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ProductPart {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  partNo    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String   @unique // e.g., "Dixon", "SAMSUNG", "IN HOUSE"
  createdAt DateTime @default(now())
}

// ==========================================
// 2. FUNCTIONAL TEST (One-Time Event)
// ==========================================
model FunctionalTest {
  id                Int      @id @default(autoincrement())

  // Basic Info
  productPartName   String   // [cite: 2]
  companySupplier   String   // [cite: 3]
  customer          String?  // [cite: master data enhancement]
  dateOfArrival     DateTime // [cite: 4]
  batchSlNo         String   // [cite: 5]
  productType       String   // e.g., SATL, FATL, FAFL [cite: 6-9]
  testName          String   // e.g., TR, CR, CD, BD [cite: 11-15]
  testCategory      String?  

  // Test Specifics
  model             String?  // e.g., RIL, P1-UI-1.5,8.5kg [cite: 29-30]
  samples           Int?     // Changed from String to Int [cite: 38-39]
  instrument        String?  // e.g., Power Meter, AC Power [cite: 43-44]
  testPurpose       String?  @db.Text // [cite: 45-46]

  // Protocol Data (Can be auto-filled from Master Data)
  testMethod        String   @db.Text // [cite: 20]
  judgementCriteria String   @db.Text // [cite: 21]

  // Results
  testObservation   String   @db.Text // [cite: 22]
  isPass            Boolean  // True = Pass, False = fail [cite: 23-25]
  testStartDate     DateTime // [cite: 17]
  testEndDate       DateTime // [cite: 18]
  testDuration      String?  // [cite: 19]

  // Relationships
  images            TestImage[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TestImage {
  id               Int            @id @default(autoincrement())
  imageUrl         String         // URL from your storage provider [cite: 26]
  functionalTestId Int
  functionalTest   FunctionalTest @relation(fields: [functionalTestId], references: [id], onDelete: Cascade)
  uploadedAt       DateTime       @default(now())
}

// ==========================================
// 3. RELIABILITY TEST (Continuous Cycle)
// ==========================================
model ReliabilityTest {
  id          Int      @id @default(autoincrement())

  // Header Data
  partName          String
  partNo            String?
  customerSupplier  String?
  testPurpose       String?  @db.Text
  sampleQuantity    Int?
  testEquipment     String?
  startDate         DateTime
  endDate           DateTime?
  reportIssueDate   DateTime?
  calibrationDueDate DateTime?
  ambientTempHumidity String?
  testPlace         String?
  standard          String?
  testMethod        String?  @db.Text
  judgementCriteria String?  @db.Text
  productType       String?
  nameOfTest        String?
  
  // Legacy/Backwards Compatibility
  modelCap    String?   // Optional for compatibility
  vendor      String?   // Optional for compatibility
  clothLoad   String?   // Optional for compatibility
  
  status      String   @default("ONGOING") // e.g., ONGOING, COMPLETED

  // Relationships
  dailyLogs   DailyLog[]
  stations    Station[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Station {
  id          String   @id // e.g., "P1-S1"
  platformId  String   // e.g., "P1"
  status      String   @default("AVAILABLE") // AVAILABLE, OCCUPIED
  
  reliabilityTestId Int?
  reliabilityTest   ReliabilityTest? @relation(fields: [reliabilityTestId], references: [id])
}

model DailyLog {
  id                  Int             @id @default(autoincrement())
  reliabilityTestId   Int
  reliabilityTest     ReliabilityTest @relation(fields: [reliabilityTestId], references: [id], onDelete: Cascade)

  // Table Rows (Expert Metrics)
  logDate             DateTime        // The specific date for this row
  noOfWashCycle       Int?
  noOfSpinCycle       Int?
  sealBellow          String?
  washTimer           String?
  gearBox             String?
  pulsator            String?
  washCurrentCycle    String?
  spinCurrentCycle    String?
  
  // New Excel Sheet Fields
  cycleCount          Int?
  pcb                 String?
  feedValve           String?
  washMotor           String?
  clutch              String?
  errorDetail         String?
  otherIssues         String?

  remarks             String?         @db.Text

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([reliabilityTestId, logDate]) // Ensures only one log per day per test
}

// ==========================================
// 5. R&D TESTING EQUIPMENT
// ==========================================
model TestingEquipment {
  id                 Int      @id @default(autoincrement())
  slNo               Int?     // Corresponding to user provided serial numbers
  name               String   @unique
  calibrationDueDate DateTime?
  
  status             String   @default("ACTIVE") // ACTIVE, OUT_OF_CALIBRATION, MAINTENANCE
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==========================================
// 6. TEST CATEGORY MANAGEMENT
// ==========================================
model TestCategory {
  id                 Int      @id @default(autoincrement())
  slNo               Int?
  name               String   @unique
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
